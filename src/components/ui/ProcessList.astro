---
interface Paso {
  titulo: string;
  descripcion: string;
}

interface Props {
  pasos: Paso[];
  eyebrow?: string;
  borderTop?: boolean;
}

const { pasos, eyebrow = 'Cómo trabajamos', borderTop = false } = Astro.props;
---

<section
  class:list={['py-24 px-6', borderTop && 'border-t border-base-ink/10']}
>
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-4 mb-16 animate-fade-in-up timeline-view animate-range-[entry_0%_cover_35%]">
      <span class="block w-10 h-px bg-base-ink/40"></span>
      <p class="text-sm font-medium tracking-widest text-base-ink/50 uppercase">
        {eyebrow}
      </p>
    </div>

    <ol class="list-none">
      {
        pasos.map((paso, i) => (
          <>
            <li
              class="grid grid-cols-[4rem_1fr] md:grid-cols-[8rem_1fr] gap-6 md:gap-12 items-start py-10 animate-fade-in-left timeline-view animate-range-[entry_0%_cover_40%]"
            >
              <span class="font-display text-5xl md:text-7xl font-bold text-base-ink/10 leading-none select-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div class="pt-2 md:pt-3">
                <h3 class="font-display text-2xl md:text-3xl font-semibold text-base-ink mb-3">
                  {paso.titulo}
                </h3>
                <p class="text-neutral-600 leading-relaxed max-w-xl">
                  {paso.descripcion}
                </p>
              </div>
            </li>
            {i < pasos.length - 1 && (
              <li aria-hidden="true" class="h-px bg-base-ink/10" />
            )}
          </>
        ))
      }
    </ol>
  </div>
</section>
