---

---

<section
  class="px-6 py-24"
  style="background-color: #8AB3DC; background-image: radial-gradient(ellipse at 0% 110%, rgba(25, 25, 25, 0.22), transparent 55%), radial-gradient(ellipse at 100% -10%, rgba(255, 255, 255, 0.25), transparent 50%);"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-end">
      <!-- Left: bold statement -->
      <div class="animate-fade-in-left timeline-view animate-range-[entry_0%_cover_45%]">
        <h2
          class="font-display text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight text-base-ink"
        >
          ¿Hablamos<br />
          <span class="italic text-base-ink/40">de tu marca?</span>
        </h2>
      </div>

      <!-- Right: copy + actions -->
      <div class="flex flex-col gap-10 animate-fade-in-right timeline-view animate-range-[entry_0%_cover_45%]">
        <p class="text-lg text-base-ink/70 leading-relaxed max-w-md">
          Cuéntanos dónde estás y a dónde quieres llegar. Sin compromisos ni
          formularios interminables — una conversación honesta para ver si
          encajamos.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-block bg-base-ink text-base-bg font-semibold px-8 py-4 rounded-full hover:bg-base-ink/80 transition-colors duration-200"
          >
            Escribenos
          </a>
          <a
            href="/about"
            class="inline-block border border-base-ink/25 text-base-ink font-semibold px-8 py-4 rounded-full hover:border-base-ink/40 hover:bg-base-ink/8 transition-colors duration-200"
          >
            Conoce el equipo →
          </a>
        </div>

        <!-- Subtle social proof -->
        <p class="text-sm text-base-ink/50 border-t border-base-ink/15 pt-8">
          Primera consulta sin coste · Respuesta en menos de 24 h
        </p>
      </div>
    </div>
  </div>
</section>
