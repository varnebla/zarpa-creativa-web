---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<section class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <p
        class="text-sm font-medium tracking-widest text-neutral-600 uppercase mb-4"
      >
        Blog
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-neutral-950">
        Ideas y tendencias
      </h1>
    </div>

    <div class="divide-y divide-neutral-200">
      {
        sorted.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col md:flex-row gap-6 md:gap-12 py-10 items-start"
          >
            <time
              datetime={post.data.pubDate.toISOString()}
              class="text-sm text-neutral-600 md:w-32 shrink-0 pt-1"
            >
              {post.data.pubDate.toLocaleDateString('es-ES', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </time>
            <div class="flex-1">
              <div class="flex gap-2 flex-wrap mb-3">
                {post.data.tags.map((tag) => (
                  <span class="text-xs font-medium text-neutral-600 uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="font-display text-2xl md:text-3xl font-semibold text-neutral-950 group-hover:text-neutral-600 transition-colors leading-snug mb-3">
                {post.data.title}
              </h2>
              <p class="text-neutral-700 leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
