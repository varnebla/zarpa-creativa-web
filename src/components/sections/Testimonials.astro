---
const testimonials = [
  {
    quote:
      'Zarpa rediseñó nuestra web y en tres meses duplicamos las consultas orgánicas. No solo entregan diseño — entregan resultados.',
    author: 'Laura Méndez',
    role: 'Fundadora, Estudio Cien',
  },
  {
    quote:
      'Trabajar con ellos fue diferente desde el primer día. Entienden el negocio antes de hablar de píxeles. Eso marca la diferencia.',
    author: 'Marcos Iniesta',
    role: 'Director de Marketing, Ferros SL',
  },
  {
    quote:
      'Nuestra comunidad en Instagram pasó de 800 a 12.000 seguidores en seis meses. Y lo mejor: son seguidores reales que compran.',
    author: 'Sofía Ruano',
    role: 'CEO, La Miel Silvestre',
  },
];
---

<section class="bg-base-ink text-base-bg px-6 py-24 md:py-32">
  <div class="max-w-6xl mx-auto">
    <p
      class="text-xs font-medium tracking-[0.15em] uppercase text-[#888] mb-5 animate-fade-in timeline-view animate-range-[entry_0%_cover_35%]"
    >
      Clientes
    </p>
    <h2
      class="font-display text-[clamp(2rem,4vw,3.2rem)] font-bold leading-[1.15] tracking-[-0.03em] text-base-bg mb-14 animate-fade-in-up timeline-view animate-range-[entry_0%_cover_40%]"
    >
      Lo que dicen<br />quienes confían en nosotros
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-px border border-white/10 rounded-2xl overflow-hidden grid-reveal"
    >
      {
        testimonials.map((t, index) => (
          <article class="bg-base-ink p-10 flex flex-col justify-between gap-8 transition-colors duration-200 hover:bg-[#242424] animate-fade-in-up">
            <blockquote class="text-[clamp(1rem,1.4vw,1.15rem)] leading-[1.65] text-[#d9d5cd] not-italic font-normal">
              "{t.quote}"
            </blockquote>
            <footer class="flex flex-col gap-[0.2rem] border-t border-white/10 pt-5">
              <span class="font-semibold text-[0.9rem] text-base-bg">
                {t.author}
              </span>
              <span class="text-[0.8rem] text-[#666]">{t.role}</span>
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</section>
