---
import { getCollection } from 'astro:content';

const servicios = await getCollection('servicios');
const sorted = servicios.sort((a, b) => a.data.order - b.data.order);
---

<section class="py-24 px-6 bg-base-bg">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <p
        class="text-sm font-medium tracking-widest text-base-ink/60 uppercase mb-4"
      >
        Lo que hacemos
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-base-ink">
        Tres servicios.<br />Un solo objetivo.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-neutral-200">
      {
        sorted.map((servicio) => (
          <a
            href={`/servicios/${servicio.id}`}
            class="group bg-base-bg p-10 hover:bg-base-ink transition-colors duration-300"
          >
            <h3 class="font-display text-2xl font-semibold text-base-ink group-hover:text-base-bg mb-4 transition-colors duration-300">
              {servicio.data.title}
            </h3>
            <p class="text-base-ink/70 group-hover:text-base-bg/70 leading-relaxed transition-colors duration-300">
              {servicio.data.excerpt}
            </p>
            <span class="inline-block mt-6 text-sm font-semibold text-base-ink group-hover:text-base-bg transition-colors duration-300">
              Ver servicio →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
