---
const serviciosLinks = [
  { label: 'SEO & Posicionamiento', href: '/servicios/seo' },
  { label: 'Social Media', href: '/servicios/social-media' },
  { label: 'Publicidad Digital', href: '/servicios/publicidad-digital' },
  { label: 'Diseño y Branding', href: '/servicios/diseno-branding' },
];

const companyLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Quiénes somos', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="bg-neutral-950 text-white">
  <div class="max-w-6xl mx-auto px-6 pt-20 pb-10">
    <!-- Top -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 pb-16 border-b border-white/10"
    >
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a
          href="/"
          class="font-display font-bold text-2xl text-white hover:text-neutral-300 transition-colors"
        >
          Zarpa Creativa
        </a>
        <p class="mt-4 text-neutral-400 leading-relaxed max-w-xs">
          Agencia de marketing digital que combina estrategia, creatividad y
          datos para hacer crecer marcas con propósito.
        </p>
        <a
          href="/contact"
          class="inline-block mt-8 border border-white/20 text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-white hover:text-neutral-950 transition-colors"
        >
          Empieza tu proyecto →
        </a>
      </div>

      <!-- Servicios -->
      <div>
        <p
          class="text-xs font-semibold tracking-widest text-neutral-500 uppercase mb-6"
        >
          Servicios
        </p>
        <ul class="space-y-3">
          {
            serviciosLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-neutral-400 hover:text-white transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <p
          class="text-xs font-semibold tracking-widest text-neutral-500 uppercase mb-6"
        >
          Empresa
        </p>
        <ul class="space-y-3">
          {
            companyLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-neutral-400 hover:text-white transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div
      class="pt-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-neutral-600"
    >
      <p>© {year} Zarpa Creativa. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="/aviso-legal" class="hover:text-neutral-400 transition-colors"
          >Aviso legal</a
        >
        <a
          href="/politica-privacidad"
          class="hover:text-neutral-400 transition-colors"
          >Política de privacidad</a
        >
        <a href="/cookies" class="hover:text-neutral-400 transition-colors"
          >Cookies</a
        >
      </div>
    </div>
  </div>
</footer>
