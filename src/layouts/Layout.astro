---
import { Font } from 'astro:assets';
import '../styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zarpa Creativa - Agencia de Marketing Digital',
  description = 'Zarpa Creativa es una agencia de marketing digital especializada en estrategia, diseño y crecimiento de marcas.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--font-general-sans" preload />
    <Font cssVariable="--font-playfair" preload />
    <slot name="head" />
  </head>
  <body class="font-sans antialiased bg-base-bg text-base-ink">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
